# ============================================
# 小票收纳小管家 - 根级 .gitignore
# ============================================

# ===== 依赖 =====
node_modules/
*/node_modules/

# ===== 构建产物 =====
client/dist/
client/dist-mobile/
mobile/android/build/
mobile/android/app/build/
mobile/android/.gradle/
mobile/android/captures/

# Capacitor 同步生成的 web 资产（由 `npx cap sync` 重新生成）
mobile/android/app/src/main/assets/public/
mobile/android/app/src/main/assets/capacitor.config.json
mobile/android/app/src/main/assets/capacitor.plugins.json

# ===== 环境变量 / 密钥（绝不入库）=====
server/.env
*.env.local
*.env.production
*.keystore
*.jks

# ===== 本地部署脚本（含服务器凭证，绝不上传）=====
ssh-deploy.mjs
mysql-tunnel.py
start-tunnel.vbs

# ===== 二进制 / 大文件 =====
*.apk
*.aab
*.ipa

# ===== 用户上传内容 =====
server/uploads/

# ===== 原始素材（设计稿等，开发文档无需上传）=====
微信图片_*.png

# ===== IDE / 编辑器 =====
.vscode/
.idea/
*.swp
*.swo
*~

# ===== 系统文件 =====
.DS_Store
Thumbs.db
desktop.ini

# ===== 日志 / 临时文件 =====
*.log
*.tmp
*.bak

# ===== 本地配置 =====
mobile/android/local.properties

# ===== 临时脚本与生成产物（不应入库）=====
.workbuddy/
apply_template_format.py
generate_report.mjs
_diag.cjs
_api_test.cjs
_sshlog.cjs
_sshdb.cjs
_sshenv.cjs
_export_db.cjs
_deploy_mysql.cjs
_verify.cjs
_db_dump.sql
_template_extract.txt

# ===== 生成的报告文档（按需单独提供，不入库）=====
票小兜项目报告*.docx
排版优化报告.md
